# SMB MCP Server - Environment Configuration Example
#
# Copy this file to .env and fill in your values
# All configuration uses JSON list format where each index corresponds to a share

# ========================================
# SMB Share Configuration (Required)
# ========================================

# Share names (identifiers for each share)
# Default: ["share_1", "share_2", ...]
SMB_NAMES='["data", "backup"]'

# SMB server hostnames or IP addresses (Required)
SMB_HOSTS='["192.168.1.100", "192.168.1.101"]'

# Remote share names on the SMB servers (Required)
SMB_SHARE_NAMES='["shared_folder", "backup_drive"]'

# Authentication usernames (Required)
SMB_USERNAMES='["user1", "user2"]'

# Authentication passwords (Required)
SMB_PASSWORDS='["password1", "password2"]'

# NT domains (Optional, default: "")
SMB_DOMAINS='["WORKGROUP", "DOMAIN"]'

# SMB ports (Optional, default: 445)
SMB_PORTS='[445, 445]'


# ========================================
# Security Configuration (Optional)
# ========================================

# Allowed file extensions
# Default: [".txt", ".py", ".json", ".md", ".yaml", ".yml", ".xml", ".csv"]
SMB_ALLOWED_EXTENSIONS='[".txt", ".py", ".json", ".md", ".yaml", ".yml", ".xml", ".csv", ".log"]'

# Blocked file extensions (takes precedence over allowed)
# Default: [".exe", ".bat", ".cmd", ".ps1", ".sh"]
SMB_BLOCKED_EXTENSIONS='[".exe", ".bat", ".cmd", ".ps1", ".sh", ".dll", ".sys"]'

# Maximum file size (supports KB, MB, GB)
# Default: 100MB
SMB_MAX_FILE_SIZE='10000MB'

# Allowed paths (empty means all paths are allowed)
# Default: []
SMB_ALLOWED_PATHS='[]'

# Blocked paths
# Default: ["/etc", "/root", "/sys", "/proc"]
SMB_BLOCKED_PATHS='["/etc", "/root", "/sys", "/proc", "/Windows/System32"]'

# Enable write operations (true/false, 1/0, yes/no, on/off)
# Default: true
SMB_ENABLE_WRITE='true'

# Enable delete operations (true/false, 1/0, yes/no, on/off)
# Default: false
SMB_ENABLE_DELETE='false'


# ========================================
# Server Configuration (Optional)
# ========================================

# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
# Default: INFO
SMB_LOG_LEVEL='INFO'

# Maximum concurrent connections
# Default: 10
SMB_MAX_CONNECTIONS='10'


# ========================================
# Usage Examples
# ========================================

# Single share configuration:
# SMB_NAMES='["data"]'
# SMB_HOSTS='["192.168.1.100"]'
# SMB_SHARE_NAMES='["shared"]'
# SMB_USERNAMES='["myuser"]'
# SMB_PASSWORDS='["mypassword"]'

# Minimal configuration (only required fields):
# SMB_HOSTS='["192.168.1.100"]'
# SMB_SHARE_NAMES='["shared"]'
# SMB_USERNAMES='["myuser"]'
# SMB_PASSWORDS='["mypassword"]'
